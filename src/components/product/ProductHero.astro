---
import HeatIndicator from './HeatIndicator.astro';

interface Props {
  product: {
    name: string;
    efLevel: number;
    efColor: string;
    scovilleMin: number;
    scovilleMax: number;
    jarImage?: string;
    jarImageAlt?: string;
  };
}

const { product } = Astro.props;

const scovilleFormatted = `${product.scovilleMin.toLocaleString()}–${product.scovilleMax.toLocaleString()} SHU`;

function getHeatLabel(level: number): string {
  switch (level) {
    case 1: return 'Mild';
    case 2: return 'Medium';
    case 3: return 'Hot';
    case 4: return 'Very Hot';
    case 5: return 'Scorching';
    default: return '';
  }
}

const heatLabel = getHeatLabel(product.efLevel);
---

<section class="product-hero">
  <div class="hero-inner">
    <div class="jar-placeholder" style={`background-color: ${product.efColor};`} aria-hidden="true">
      {product.jarImage ? (
        <img
          src={product.jarImage}
          alt={product.jarImageAlt ?? `${product.name} hot sauce jar`}
          class="jar-image"
        />
      ) : (
        <span class="jar-placeholder-text">EF-{product.efLevel}</span>
      )}
    </div>

    <div class="hero-content">
      <HeatIndicator efLevel={product.efLevel} efColor={product.efColor} />
      <h1 class="product-name">{product.name}</h1>
      <div class="scoville-container" aria-label={`Heat level: ${heatLabel}, ${scovilleFormatted}`}>
        <span class="heat-label">{heatLabel}</span>
        <span class="shu-wrapper">
          <span class="shu-value">({scovilleFormatted})</span>
          <div class="shu-tooltip" role="tooltip">
            <strong>Scoville Heat Units (SHU)</strong> measure the concentration of capsaicin, the chemical responsible for chili pepper heat. Our EF scale maps these scientific measurements to real-world storm intensity.
          </div>
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .product-hero {
    background: var(--storm-charcoal);
    color: var(--premium-white);
    padding: 3rem 1.5rem;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .jar-placeholder {
    width: 200px;
    height: 280px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .jar-placeholder-text {
    font-size: 2rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.6);
  }

  .jar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-name {
    font-size: 3rem;
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
  }

  .scoville-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.125rem;
    margin: 0;
  }

  .heat-label {
    font-weight: 800;
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .shu-wrapper {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.4);
    line-height: 1.2;
    opacity: 0.9;
  }

  .shu-value {
    font-variant-numeric: tabular-nums;
  }

  .shu-tooltip {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    width: max-content;
    max-width: 300px;
    background: var(--premium-white);
    color: var(--storm-charcoal);
    padding: 1rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 50;
    line-height: 1.5;
    text-align: left;
    pointer-events: none;
  }
  
  .shu-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 8px;
    border-style: solid;
    border-color: var(--premium-white) transparent transparent transparent;
  }

  .shu-wrapper:hover .shu-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  
  .shu-tooltip strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--accent-gold);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
