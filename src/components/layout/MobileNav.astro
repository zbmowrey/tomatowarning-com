---
import { siteConfig } from '@/config/site';
---

<!-- CSS-only toggle using checkbox hack -->
<input type="checkbox" id="mobile-nav-toggle" class="mobile-nav-toggle" aria-hidden="true" />

<div class="mobile-nav-overlay" role="dialog" aria-label="Mobile navigation" aria-modal="true">
  <label for="mobile-nav-toggle" class="close-btn" aria-label="Close menu">
    <span aria-hidden="true">&times;</span>
  </label>

  <nav aria-label="Mobile navigation">
    <ul>
      {siteConfig.nav.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .mobile-nav-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    background: var(--storm-charcoal);
    color: var(--premium-white);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
    transform: translateX(100%);
    transition: transform 0.25s ease;
  }

  .mobile-nav-toggle:checked ~ .mobile-nav-overlay {
    transform: translateX(0);
  }

  .close-btn {
    align-self: flex-end;
    font-size: 2rem;
    cursor: pointer;
    color: var(--premium-white);
    line-height: 1;
    margin-bottom: 2rem;
  }

  .mobile-nav-overlay nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mobile-nav-overlay nav a {
    color: var(--premium-white);
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .mobile-nav-overlay nav a:hover {
    color: var(--radar-teal);
  }

  @media (min-width: 769px) {
    .mobile-nav-overlay {
      display: none;
    }
  }
</style>
