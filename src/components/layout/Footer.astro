---
import { siteConfig } from '@/config/site';
import type { NavItem } from '@/config/site';
import PrivacyLink from '@/components/common/PrivacyLink.astro';

// Flatten nav items: top-level links + all children from dropdowns
const footerLinks = (siteConfig.nav as readonly NavItem[]).flatMap((item) =>
  item.children ? item.children : item.href ? [{ label: item.label, href: item.href }] : []
);
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Slot for FooterSignupForm island -->
    <div class="footer-signup">
      <slot />
      <noscript>
        <p class="noscript-notice">
          Want to stay updated?
          <a href="mailto:hello@tomatowarning.com">Email us at hello@tomatowarning.com</a>
        </p>
      </noscript>
    </div>

    <div class="footer-bottom">
      <nav aria-label="Footer navigation" class="footer-nav">
        <ul>
          {footerLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer-meta">
        <PrivacyLink />
        <span class="copyright">&copy; 2026 Tomato Warning</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--storm-charcoal);
    color: var(--premium-white);
    margin-top: auto;
    border-top: 2px solid var(--accent-gold);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-signup {
    border-bottom: 1px solid rgba(245, 240, 235, 0.15);
    padding-bottom: 2rem;
  }

  .noscript-notice {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .noscript-notice a {
    color: var(--accent-gold);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-nav a {
    color: var(--premium-white);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.75;
    transition: opacity 0.15s;
  }

  .footer-nav a:hover {
    opacity: 1;
    color: var(--accent-gold);
  }

  .footer-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .copyright {
    font-size: 0.875rem;
    color: var(--text-muted-dark);
  }
</style>
