---
/**
 * JarImage.astro — Single jar render with Astro Image optimization.
 * Falls back to an EF-color placeholder div when jarImage path is absent
 * (real renders delivered by P1-15, not yet available at build time).
 */
import { Image } from 'astro:assets';
import defaultJar from '@/assets/images/hero/jar-mockup.png';

interface Props {
  /** Path to jar image asset. When empty/undefined, renders EF-color placeholder. */
  src: string;
  alt: string;
  efLevel: number;
  efColor: string;
  /** Width in px for Astro Image and placeholder sizing */
  width?: number;
  /** Height in px for Astro Image and placeholder sizing */
  height?: number;
  /** Load eagerly + fetchpriority="high" for above-the-fold hero images */
  eager?: boolean;
  class?: string;
}

const {
  src,
  alt,
  efLevel,
  efColor,
  width = 200,
  height = 260,
  eager = false,
  class: className,
} = Astro.props;

// If the source looks like a default/mock or missing path, we use our premium default jar
const hasImage = src && src.trim() !== '';
const isMockup = hasImage && (src.includes('placeholder') || src.includes('mockup'));
---

{hasImage && !isMockup ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    class:list={['jar-image', className]}
    style={`width: ${width}px; height: ${height}px; object-fit: cover;`}
  />
) : (
  <img
    src={defaultJar.src}
    alt={alt || 'Premium salsa jar mockup'}
    width={width}
    height={height}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    class:list={['jar-image', className]}
    style={`width: ${width}px; height: ${height}px; object-fit: cover;`}
  />
)}

<style>
  .jar-image {
    border-radius: 6px;
    display: block;
  }

  .jar-placeholder {
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .jar-placeholder-label {
    font-size: 1.5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.05em;
  }
</style>
