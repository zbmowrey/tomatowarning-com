---
/**
 * HeroSection.astro — Homepage hero section.
 * Static, zero client JS. Hardcoded copy per implementation plan decision.
 * Contains: h1 headline, sub-copy (Scoville + batch consistency), EF definition,
 * EFScaleBar, and CTA to /mission/.
 */
import EFScaleBar from './EFScaleBar.astro';
import CTAButton from '@/components/common/CTAButton.astro';
import { Picture } from 'astro:assets';
import stormBg from '@/assets/images/hero/storm-bg-panoramic.png';
---

<section class="hero-section" aria-labelledby="hero-headline">
  <div class="hero-bg-wrapper">
    <Picture 
      src={stormBg} 
      alt="Dark cinematic storm clouds building on the horizon" 
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      formats={['avif', 'webp']}
      fallbackFormat="png"
      pictureAttributes={{ class: 'hero-bg-picture' }}
      class="hero-bg-image" 
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-bg-overlay"></div>
  </div>
  <div class="hero-texture" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="hero-eyebrow">Premium Florida Salsa — Rated by the Storm</p>

      <h1 id="hero-headline" class="hero-headline">
        Five Salsas. One Storm Scale.
      </h1>

      <p class="hero-subheadline">
        Every jar rated EF-1 to EF-5 with published Scoville ranges. Complex flavor at every level. No guesswork.
      </p>

      <div class="hero-ef-definition" aria-label="What is the EF scale?">
        <span class="ef-definition-label">What is EF?</span>
        <p class="ef-definition-text">
          The Enhanced Fujita scale rates tornado intensity from EF-1 (minor) to EF-5 (catastrophic).
          We use it to rate heat — so you always know exactly what you are getting.
        </p>
      </div>

      <div class="hero-cta">
        <CTAButton href="/products/" variant="primary" text="Find Your EF Level" />
        <CTAButton href="/mission/" variant="secondary" text="Our Mission" />
      </div>
    </div>

    <div class="hero-scale-wrap" aria-label="The EF heat scale">
      <EFScaleBar />
    </div>
  </div>
</section>

<style>
  .hero-section {
    background-color: var(--storm-charcoal);
    color: var(--premium-white);
    padding: 5rem 1.5rem 4rem;
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  
  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  
  .hero-bg-picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  
  .hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%; /* Balances sky and horizon */
  }
  
  /* On ultrawide monitors, shift focus slightly up to ensure the storm drama isn't cropped out completely */
  @media (min-aspect-ratio: 16/9) {
    .hero-bg-image {
      object-position: center 35%;
    }
  }
  
  @media (min-aspect-ratio: 21/9) {
    .hero-bg-image {
      object-position: center 25%;
    }
  }
  
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(44, 44, 44, 0.4) 0%,
      rgba(44, 44, 44, 0.8) 50%,
      rgba(44, 44, 44, 0.95) 100%
    );
  }

  .hero-texture {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: radial-gradient(var(--accent-gold) 1px, transparent 1px);
    background-size: 32px 32px;
    background-position: -16px -16px;
    opacity: 0.05;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    z-index: 10;
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-gold);
    margin: 0;
  }

  .hero-headline {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0;
    color: var(--premium-white);
  }

  .hero-subheadline {
    font-size: 1.125rem;
    line-height: 1.65;
    opacity: 0.8;
    margin: 0;
    max-width: 42ch;
  }

  .hero-ef-definition {
    border-left: 3px solid var(--accent-gold);
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ef-definition-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-gold);
  }

  .ef-definition-text {
    font-size: 0.875rem;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .hero-scale-wrap {
    padding: 1rem 0;
    position: relative;
    z-index: 10;
  }

  /* Responsive: stack on smaller screens */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-section {
      min-height: auto;
      padding: 4rem 1.5rem 3rem;
    }
  }

  @media (max-width: 480px) {
    .hero-headline {
      font-size: 2.75rem;
    }
  }
</style>
