---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import ProductCard from '@/components/product/ProductCard.astro';

const allProducts = await getCollection('products');

const publishedProducts = import.meta.env.PROD
  ? allProducts.filter((p) => p.data.status !== 'draft')
  : allProducts;

const sortedProducts = publishedProducts.sort((a, b) => a.data.efLevel - b.data.efLevel);
---

<PageLayout
  title="Hot Sauces | Tomato Warning"
  description="All five EF levels of Tomato Warning hot sauce — from Coastal Calm (EF-1) to Ground Zero (EF-5). Flavor on the radar."
  canonicalPath="/products/"
>
  <section class="products-section">
    <div class="products-inner">
      <header class="products-header">
        <h1>The Lineup</h1>
        <p class="products-subtitle">Five levels. All storm. No apologies.</p>
      </header>

      {sortedProducts.length > 0 ? (
        <div class="products-grid">
          {sortedProducts.map((product) => (
            <ProductCard product={product.data} />
          ))}
        </div>
      ) : (
        <p class="no-products">Products launching soon. Sign up below to be notified.</p>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .products-section {
    padding: 3rem 1.5rem;
  }

  .products-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .products-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .products-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--storm-charcoal);
  }

  .products-subtitle {
    font-size: 1.125rem;
    color: var(--storm-charcoal);
    opacity: 0.7;
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .no-products {
    text-align: center;
    font-size: 1.125rem;
    color: var(--storm-charcoal);
    opacity: 0.7;
  }
</style>
