---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import ProductCard from '@/components/product/ProductCard.astro';

const allProducts = await getCollection('products');

const publishedProducts = import.meta.env.PROD
  ? allProducts.filter((p) => p.data.status !== 'draft')
  : allProducts;

const sortedProducts = publishedProducts.sort((a, b) => a.data.efLevel - b.data.efLevel);
---

<PageLayout
  title="The Lineup — Premium Salsa EF-1 to EF-5 | Tomato Warning"
  description="Five premium salsas rated on the Enhanced Fujita scale — from EF-1 Coastal Calm to EF-5 Ground Zero. Published Scoville ranges. Find your level."
  canonicalPath="/products/"
>
  <section class="products-section">
    <div class="products-inner">
      <header class="products-header">
        <h1>The Lineup</h1>
        <p class="products-subtitle">EF-1 to EF-5. From a gentle coastal breeze to total devastation. Find your level.</p>
      </header>

      {sortedProducts.length > 0 ? (
        <div class="products-grid">
          {sortedProducts.map((product) => (
            <ProductCard product={product.data} />
          ))}
        </div>
      ) : (
        <p class="no-products">The storm is building. Five salsas, EF-1 to EF-5 — launching soon. Join the Storm below to get first access.</p>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .products-section {
    padding: 3rem 1.5rem;
  }

  .products-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .products-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .products-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--storm-charcoal);
  }

  .products-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted-light);
    margin: 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .no-products {
    text-align: center;
    font-size: 1.125rem;
    color: var(--storm-charcoal);
    opacity: 0.7;
  }
</style>
