---
import { getCollection } from 'astro:content';
import ProductLayout from '@/layouts/ProductLayout.astro';
import ProductHero from '@/components/product/ProductHero.astro';
import ProductDetails from '@/components/product/ProductDetails.astro';
import ProductNav from '@/components/product/ProductNav.astro';
import { FooterSignupForm } from '@/components/forms/FooterSignupForm';
import { FORM_ENDPOINT, formConfigs } from '@/config/forms';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');

  const publishedProducts = import.meta.env.PROD
    ? allProducts.filter((p) => p.data.status !== 'draft')
    : allProducts;

  // Sort products by EF Level before mapping to ensure correct prev/next order
  const sortedProducts = publishedProducts.sort((a, b) => a.data.efLevel - b.data.efLevel);

  return sortedProducts.map((product, index) => {
    return {
      params: { slug: product.data.slug },
      props: { 
        product: product.data,
        prevProduct: index > 0 ? sortedProducts[index - 1].data : sortedProducts[sortedProducts.length - 1].data,
        nextProduct: index < sortedProducts.length - 1 ? sortedProducts[index + 1].data : sortedProducts[0].data,
      },
    };
  });
}

const { product, prevProduct, nextProduct } = Astro.props;
const canonicalPath = `/products/${product.slug}/`;
---

<ProductLayout product={product} canonicalPath={canonicalPath}>
  <ProductHero product={product} />
  <ProductDetails product={product} />
  <ProductNav prevProduct={prevProduct} nextProduct={nextProduct} />

  <FooterSignupForm
    slot="footer-form"
    client:visible
    formEndpoint={FORM_ENDPOINT}
    consumerListId={formConfigs.consumer.listId}
    retailerListId={formConfigs.retailer.listId}
    successMessage={formConfigs.consumer.successMessage}
    alreadySubscribedMessage={formConfigs.consumer.alreadySubscribedMessage}
    noscriptFallbackUrl={formConfigs.consumer.noscriptFallbackUrl}
    privacyPolicyUrl="/privacy/"
  />
</ProductLayout>
