---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/hero/HeroSection.astro';
import ProductCard from '@/components/product/ProductCard.astro';
import { ConsumerSignupForm } from '@/components/forms/ConsumerSignupForm';
import { FooterSignupForm } from '@/components/forms/FooterSignupForm';
import { FORM_ENDPOINT, consumerFormConfig, formConfigs } from '@/config/forms';

const allProducts = await getCollection('products');
const publishedProducts = import.meta.env.PROD
  ? allProducts.filter((p) => p.data.status !== 'draft')
  : allProducts;
const sortedProducts = publishedProducts.sort((a, b) => a.data.efLevel - b.data.efLevel);

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tomato Warning',
  url: 'https://tomatowarning.com',
  description:
    'Premium small-batch Florida salsa rated on the Enhanced Fujita tornado scale. Five heat levels with published Scoville ranges. Flavor-first. Mission-driven. Chase the storm.',
  sameAs: [],
};
---

<PageLayout
  title="Tomato Warning — Premium Salsa | Chase the Storm"
  description="Premium Florida salsa rated EF-1 to EF-5 on the Enhanced Fujita scale. Published Scoville ranges, complex flavor at every level, and 10% of net profits to disaster relief."
  canonicalPath="/"
  structuredData={organizationJsonLd}
>
  <HeroSection />

  {sortedProducts.length > 0 && (
    <section class="products-section" aria-labelledby="products-heading">
      <div class="products-inner">
        <h2 id="products-heading" class="products-heading">The Lineup</h2>
        <p class="products-sub">EF-1 to EF-5. From a gentle coastal breeze to total devastation. Find your level.</p>
        <div class="products-grid">
          {sortedProducts.map((product) => (
            <ProductCard product={product.data} headingLevel={3} />
          ))}
        </div>
      </div>
    </section>
  )}


  <FooterSignupForm
    slot="footer-form"
    client:visible
    formEndpoint={FORM_ENDPOINT}
    consumerListId={formConfigs.consumer.listId}
    retailerListId={formConfigs.retailer.listId}
    nonprofitListId={formConfigs.nonprofit.listId}
    successMessage={formConfigs.consumer.successMessage}
    alreadySubscribedMessage={formConfigs.consumer.alreadySubscribedMessage}
    noscriptFallbackUrl={formConfigs.consumer.noscriptFallbackUrl}
    privacyPolicyUrl="/privacy/"
  />
</PageLayout>

<style>
  .products-section {
    padding: 5rem 1.5rem;
    background: var(--premium-white);
  }

  .products-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .products-heading {
    font-size: 2rem;
    font-weight: 800;
    color: var(--storm-charcoal);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  .products-sub {
    text-align: center;
    font-size: 1.125rem;
    color: var(--text-muted-light);
    margin: 0 0 3rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }


</style>
