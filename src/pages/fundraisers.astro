---
import PageLayout from '@/layouts/PageLayout.astro';
import { NonprofitSignupForm } from '@/components/forms/NonprofitSignupForm';
import { FooterSignupForm } from '@/components/forms/FooterSignupForm';
import { FORM_ENDPOINT, nonprofitFormConfig, formConfigs } from '@/config/forms';
---

<PageLayout
  title="Fundraiser Program — 50% Margins | Tomato Warning"
  description="Raise money with Tomato Warning premium salsa. Your organization keeps 50% of every sale. No upfront cost, shelf-stable product, and a built-in story that sells itself."
  canonicalPath="/fundraisers/"
>
  <article class="fundraisers-page">
    <div class="fundraisers-inner">

      <header class="page-header">
        <p class="eyebrow">Community Partner Program</p>
        <h1>Raise more. Sell less.</h1>
        <p class="page-lead">
          Your organization keeps 50% of every jar sold. No upfront cost, no freezer logistics, no leftover inventory. Premium salsa with a built-in story families actually want to hear — and a price point that means fewer sales to hit your goal.
        </p>
      </header>

      <div class="fundraisers-body">
        <div class="fundraisers-value">
          <h2>Why it works</h2>
          <ul class="benefits-list">
            <li>
              <div class="benefit-icon" aria-hidden="true">50%</div>
              <div class="benefit-text">
                <strong>50% stays with your organization.</strong>
                <p>One of the highest margins in food fundraising. No tiering, no hidden fees. Sell 200 jars, keep $1,000.</p>
              </div>
            </li>
            <li>
              <div class="benefit-icon" aria-hidden="true">$0</div>
              <div class="benefit-text">
                <strong>Zero upfront cost.</strong>
                <p>We fulfill orders after your campaign closes. No inventory risk, no leftover product, no money out of pocket.</p>
              </div>
            </li>
            <li>
              <div class="benefit-icon" aria-hidden="true">+</div>
              <div class="benefit-text">
                <strong>Shelf-stable and premium.</strong>
                <p>No melting chocolate, no frozen cookie dough, no logistics headaches. Glass jars, real ingredients, a product families reach for long after the fundraiser ends.</p>
              </div>
            </li>
            <li>
              <div class="benefit-icon" aria-hidden="true">TW</div>
              <div class="benefit-text">
                <strong>Your logo on the label.</strong>
                <p>Custom labels put your team name front and center. Minimum quantities apply.</p>
              </div>
            </li>
          </ul>

          <div class="who-qualifies">
            <h3>Who qualifies</h3>
            <p>
              Youth sports teams, schools, scout troops, nonprofits, churches, and community organizations.
            </p>
          </div>

          <div class="dual-mission">
            <h3>The pitch writes itself</h3>
            <p>
              "Buy premium salsa your family will actually eat, support the team, and help communities recover from storms." Three wins in one jar. Your sellers don't have to convince anyone — they just have to tell the story.
            </p>
          </div>
        </div>

        <div class="fundraisers-form">
          <h2>Start Your Fundraiser</h2>
          <p class="form-intro">
            Tell us about your organization and your fundraising goal. We will send a free sample kit and everything you need to launch your campaign.
          </p>
          <NonprofitSignupForm
            client:visible
            formEndpoint={FORM_ENDPOINT}
            listId={nonprofitFormConfig.listId}
            analyticsEvent="nonprofit_signup"
            successMessage={nonprofitFormConfig.successMessage}
            alreadySubscribedMessage={nonprofitFormConfig.alreadySubscribedMessage}
            noscriptFallbackUrl={nonprofitFormConfig.noscriptFallbackUrl}
            sourceContext="fundraisers"
            privacyPolicyUrl="/privacy/"
          />
        </div>
      </div>

    </div>
  </article>

  <FooterSignupForm
    slot="footer-form"
    client:visible
    formEndpoint={FORM_ENDPOINT}
    consumerListId={formConfigs.consumer.listId}
    retailerListId={formConfigs.retailer.listId}
    nonprofitListId={formConfigs.nonprofit.listId}
    successMessage={formConfigs.consumer.successMessage}
    alreadySubscribedMessage={formConfigs.consumer.alreadySubscribedMessage}
    noscriptFallbackUrl={formConfigs.consumer.noscriptFallbackUrl}
    privacyPolicyUrl="/privacy/"
  />
</PageLayout>

<style>
  .fundraisers-page {
    padding: 4rem 1.5rem;
  }

  .fundraisers-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .page-header {
    max-width: 720px;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--radar-teal);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--storm-charcoal);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .page-lead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--storm-charcoal);
    opacity: 0.8;
    margin: 0;
    max-width: 60ch;
  }

  .fundraisers-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .fundraisers-value h2,
  .fundraisers-form h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 1.5rem;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .benefits-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .benefit-icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--radar-teal);
    color: #fff;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .benefit-text strong {
    display: block;
    font-size: 0.9375rem;
    color: var(--storm-charcoal);
    margin-bottom: 0.2rem;
  }

  .benefit-text p {
    font-size: 0.875rem;
    color: var(--text-muted-light);
    margin: 0;
    line-height: 1.5;
  }

  .who-qualifies h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 0.5rem;
  }

  .who-qualifies p {
    font-size: 0.9rem;
    color: var(--text-muted-light);
    line-height: 1.6;
    margin: 0;
  }

  .dual-mission {
    margin-top: 2rem;
  }

  .dual-mission h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 0.5rem;
  }

  .dual-mission p {
    font-size: 0.9rem;
    color: var(--text-muted-light);
    line-height: 1.6;
    margin: 0;
  }

  .form-intro {
    font-size: 0.9375rem;
    color: var(--text-muted-light);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .fundraisers-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* Ensure large tap targets on mobile */
  @media (max-width: 600px) {
    .benefit-icon {
      width: 3rem;
      height: 3rem;
    }
  }
</style>
