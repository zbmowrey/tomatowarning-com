---
import PageLayout from '@/layouts/PageLayout.astro';
import AssetDownload from '@/components/press/AssetDownload.astro';
import { PressInquiryForm } from '@/components/forms/PressInquiryForm';
import { FooterSignupForm } from '@/components/forms/FooterSignupForm';
import { FORM_ENDPOINT, formConfigs } from '@/config/forms';

// Asset URLs — empty strings trigger the "not available" state
const brandKitUrl = import.meta.env.PUBLIC_BRAND_KIT_URL ?? '';
const factSheetUrl = import.meta.env.PUBLIC_FACT_SHEET_PDF_URL ?? '';

// CF Worker endpoint — optional, falls back to mailto in PressInquiryForm
const pressWorkerEndpoint = import.meta.env.PUBLIC_PRESS_INQUIRY_ENDPOINT ?? '';
---

<PageLayout
  title="Press — Tomato Warning"
  description="Press resources for Tomato Warning — a premium Florida salsa brand rated EF-1 to EF-5 on the Enhanced Fujita scale. Brand overview, founder story, product data, and media contact."
  canonicalPath="/press/"
>
  <article class="press-page">
    <div class="press-inner">

      <header class="page-header">
        <p class="eyebrow">Press</p>
        <h1>Storm Watch.</h1>
        <p class="page-lead">
          Everything media, food writers, and podcast hosts need to cover Tomato Warning — a premium Florida salsa brand rated on the tornado scale, with a real origin story and a mission that funds disaster relief.
        </p>
      </header>

      <div class="press-body">
        <div class="press-content">

          <section class="press-section" aria-labelledby="brand-overview-heading">
            <h2 id="brand-overview-heading">Brand Overview</h2>
            <p>
              Tomato Warning is a premium small-batch salsa brand rated on the Enhanced Fujita tornado scale — the same system meteorologists use to classify tornadoes. Five products, EF-1 through EF-5, spanning Coastal Calm (500-1,500 SHU) to Ground Zero (200,000-350,000 SHU). Published Scoville ranges on every jar. Flavor-first formulation at every heat level.
            </p>
            <p>
              The brand addresses a gap no other salsa company has solved: inconsistent heat labeling. No FDA or USDA standard exists for "mild," "medium," or "hot." The EF scale replaces guesswork with published data. At least 10% of net profits fund named regional disaster relief organizations — reported annually with specific dollar amounts.
            </p>
          </section>

          <section class="press-section" aria-labelledby="founder-heading">
            <h2 id="founder-heading">Origin Story</h2>
            <p>
              During a summer storm in Southern Illinois, a three-year-old boy named Max looked up at his dad and said, "Daddy, there's a Tomato Warning." He meant tornado. The name stuck — first as a family joke, then as something more.
            </p>
            <p>
              When the family moved to Florida, storms followed. Gulf Coast hurricanes. Devastation across the Southeast. Watching communities lose everything and rebuild from nothing changed the meaning of that innocent mispronunciation.
            </p>
            <p>
              Tomato Warning became a premium salsa brand rated on the Enhanced Fujita tornado scale — EF-1 through EF-5, from a gentle coastal breeze to total devastation. Five salsas. Five storms. At least 10% of net profits go directly to disaster relief organizations helping communities recover from the real thing. A kid said the wrong word at the right time. Now it means something.
            </p>
          </section>

          <section class="press-section" aria-labelledby="facts-heading">
            <h2 id="facts-heading">Fast Facts</h2>
            <dl class="fact-list">
              <div class="fact-item">
                <dt>Founded</dt>
                <dd>2026</dd>
              </div>
              <div class="fact-item">
                <dt>Based in</dt>
                <dd>Gulf Coast, Florida</dd>
              </div>
              <div class="fact-item">
                <dt>Product</dt>
                <dd>Premium small-batch salsa, five EF-rated heat levels</dd>
              </div>
              <div class="fact-item">
                <dt>Scoville range</dt>
                <dd>500 SHU (EF-1) to 350,000 SHU (EF-5)</dd>
              </div>
              <div class="fact-item">
                <dt>Status</dt>
                <dd>Pre-launch — DTC and Gulf Coast farmers markets</dd>
              </div>
              <div class="fact-item">
                <dt>Mission</dt>
                <dd>At least 10% of net profits to regional disaster relief organizations, reported annually</dd>
              </div>
            </dl>
          </section>

          <section class="press-section" aria-labelledby="assets-heading">
            <h2 id="assets-heading">Downloads</h2>
            <div class="asset-list">
              {brandKitUrl ? (
                <AssetDownload
                  href={brandKitUrl}
                  label="Brand Kit"
                  description="High-resolution logos, color palette, typography guidelines"
                  fileType="ZIP"
                />
              ) : (
                <p class="asset-unavailable">Brand kit — available at launch. Contact us to request early access.</p>
              )}

              {factSheetUrl ? (
                <AssetDownload
                  href={factSheetUrl}
                  label="Product Fact Sheet"
                  description="EF scale overview, Scoville data, ingredient highlights, SKU list"
                  fileType="PDF"
                />
              ) : (
                <p class="asset-unavailable">Fact sheet — available at launch. Submit an inquiry for advance copy.</p>
              )}
            </div>
          </section>

        </div>

        <div class="press-contact">
          <h2>Press Inquiry</h2>
          <p class="form-intro">
            Covering specialty food, heat culture, or mission-driven brands? We respond to all press inquiries within two business days and can provide founder interviews, product samples, and high-resolution assets.
          </p>
          <PressInquiryForm
            client:visible
            submitEndpoint={pressWorkerEndpoint || undefined}
            fallbackMailto="mailto:press@tomatowarning.com"
            successMessage="Received. We'll be in touch within two business days with everything you need."
            privacyPolicyUrl="/privacy/"
          />
        </div>
      </div>

    </div>
  </article>

  <FooterSignupForm
    slot="footer-form"
    client:visible
    formEndpoint={FORM_ENDPOINT}
    consumerListId={formConfigs.consumer.listId}
    retailerListId={formConfigs.retailer.listId}
    nonprofitListId={formConfigs.nonprofit.listId}
    successMessage={formConfigs.consumer.successMessage}
    alreadySubscribedMessage={formConfigs.consumer.alreadySubscribedMessage}
    noscriptFallbackUrl={formConfigs.consumer.noscriptFallbackUrl}
    privacyPolicyUrl="/privacy/"
  />
</PageLayout>

<style>
  .press-page {
    padding: 4rem 1.5rem;
  }

  .press-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .page-header {
    max-width: 720px;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--radar-teal);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--storm-charcoal);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .page-lead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--storm-charcoal);
    opacity: 0.8;
    margin: 0;
    max-width: 60ch;
  }

  .press-body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .press-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .press-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--radar-teal);
    display: inline-block;
  }

  .press-section p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--storm-charcoal);
    margin: 0 0 0.75rem;
  }

  .press-section p:last-child {
    margin-bottom: 0;
  }

  .fact-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0;
  }

  .fact-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .fact-item dt {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--radar-teal);
  }

  .fact-item dd {
    font-size: 0.9rem;
    color: var(--storm-charcoal);
    margin: 0;
  }

  .asset-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .asset-unavailable {
    font-size: 0.875rem;
    color: var(--storm-charcoal);
    opacity: 0.55;
    font-style: italic;
    margin: 0;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(44, 44, 44, 0.1);
  }

  .press-contact {
    position: sticky;
    top: 5rem;
  }

  .press-contact h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 0.75rem;
  }

  .form-intro {
    font-size: 0.9rem;
    color: var(--storm-charcoal);
    opacity: 0.7;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .press-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .press-contact {
      position: static;
    }

    .fact-list {
      grid-template-columns: 1fr;
    }
  }
</style>
