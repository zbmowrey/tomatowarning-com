---
import PageLayout from '@/layouts/PageLayout.astro';
import AssetDownload from '@/components/press/AssetDownload.astro';
import { RetailerSignupForm } from '@/components/forms/RetailerSignupForm';
import { FooterSignupForm } from '@/components/forms/FooterSignupForm';
import { FORM_ENDPOINT, retailerFormConfig, formConfigs } from '@/config/forms';

// Retailer spec sheet PDF — conditional: show download if exists, "Request spec sheet" if not
const specSheetUrl = import.meta.env.PUBLIC_RETAILER_SPEC_SHEET_URL ?? '';
---

<PageLayout
  title="Stock the Storm | Tomato Warning"
  description="Carry Tomato Warning in your store. Get wholesale pricing, placement details, and the spec sheet. Inquire now."
  canonicalPath="/retailers/"
>
  <article class="retailers-page">
    <div class="retailers-inner">

      <header class="page-header">
        <p class="eyebrow">Wholesale</p>
        <h1>Stock the Storm.</h1>
        <p class="page-lead">
          Five heat levels. A story your customers will tell. Tomato Warning is built for specialty
          food, outdoor, and grocery buyers who want something that actually means something on the shelf.
        </p>
      </header>

      <div class="retailers-body">
        <div class="retailers-value">
          <h2>Why Tomato Warning</h2>
          <ul class="value-list">
            <li>
              <strong>A scale people understand.</strong> The EF system gives customers an immediate,
              intuitive way to choose their heat level — no guessing, no heat-scale fatigue.
            </li>
            <li>
              <strong>Five SKUs, one story.</strong> The lineup from EF-1 Coastal Calm to EF-5 Ground Zero
              tells a coherent story that drives multi-unit purchases.
            </li>
            <li>
              <strong>Florida-made, batch consistent.</strong> Every jar is Scoville-verified.
              Your customers won't be surprised.
            </li>
            <li>
              <strong>Charitable mission built in.</strong> A portion of every sale supports community
              organizations — a story worth telling at the shelf.
            </li>
          </ul>

          <div class="spec-sheet-wrap">
            {specSheetUrl ? (
              <AssetDownload
                href={specSheetUrl}
                label="Retailer Spec Sheet"
                description="Product dimensions, case counts, pricing tiers, and placement guidance"
                fileType="PDF"
              />
            ) : (
              <div class="spec-request">
                <p class="spec-request-text">
                  Spec sheet available on request — submit the form and we'll send it directly.
                </p>
              </div>
            )}
          </div>
        </div>

        <div class="retailers-form">
          <h2>Wholesale Inquiry</h2>
          <p class="form-intro">
            Tell us about your store. We'll follow up with pricing, minimums, and placement details.
          </p>
          <RetailerSignupForm
            client:visible
            formEndpoint={FORM_ENDPOINT}
            listId={retailerFormConfig.listId}
            analyticsEvent="retailer_signup"
            successMessage={retailerFormConfig.successMessage}
            alreadySubscribedMessage={retailerFormConfig.alreadySubscribedMessage}
            noscriptFallbackUrl={retailerFormConfig.noscriptFallbackUrl}
            sourceContext="retailers"
            privacyPolicyUrl="/privacy/"
          />
        </div>
      </div>

    </div>
  </article>

  <FooterSignupForm
    slot="footer-form"
    client:visible
    formEndpoint={FORM_ENDPOINT}
    consumerListId={formConfigs.consumer.listId}
    retailerListId={formConfigs.retailer.listId}
    nonprofitListId={formConfigs.nonprofit.listId}
    successMessage={formConfigs.consumer.successMessage}
    alreadySubscribedMessage={formConfigs.consumer.alreadySubscribedMessage}
    noscriptFallbackUrl={formConfigs.consumer.noscriptFallbackUrl}
    privacyPolicyUrl="/privacy/"
  />
</PageLayout>

<style>
  .retailers-page {
    padding: 4rem 1.5rem;
  }

  .retailers-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .page-header {
    max-width: 720px;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--radar-teal);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--storm-charcoal);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .page-lead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--storm-charcoal);
    opacity: 0.8;
    margin: 0;
    max-width: 60ch;
  }

  .retailers-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .retailers-value h2,
  .retailers-form h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--storm-charcoal);
    margin: 0 0 1rem;
  }

  .value-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .value-list li {
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--storm-charcoal);
  }

  .value-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--radar-teal);
    font-weight: 700;
  }

  .spec-request {
    border: 1px dashed rgba(44, 44, 44, 0.2);
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .spec-request-text {
    font-size: 0.875rem;
    color: var(--storm-charcoal);
    opacity: 0.65;
    margin: 0;
    font-style: italic;
  }

  .form-intro {
    font-size: 0.9375rem;
    color: var(--storm-charcoal);
    opacity: 0.7;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .retailers-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
