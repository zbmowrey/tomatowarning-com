---
import { getEntry } from 'astro:content';
import { render } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';

const entry = await getEntry('pages', 'privacy');

if (!entry) {
  return Astro.redirect('/');
}

const { Content } = await render(entry);
const { title, seoTitle, seoDescription, lastUpdated, noIndex } = entry.data;

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout
  title={seoTitle}
  description={seoDescription}
  canonicalPath="/privacy/"
  noIndex={noIndex}
>
  <article class="privacy-page">
    <div class="prose-inner">
      <header class="page-header">
        <h1>{title}</h1>
        <p class="last-updated">Last updated: <time datetime={lastUpdated.toISOString()}>{formattedDate}</time></p>
      </header>

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .privacy-page {
    padding: 3rem 1.5rem;
  }

  .prose-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(44, 44, 44, 0.15);
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--storm-charcoal);
  }

  .last-updated {
    font-size: 0.875rem;
    color: var(--text-muted-light);
    margin: 0;
  }

  .prose {
    color: var(--storm-charcoal);
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .prose :global(a) {
    color: var(--radar-teal);
    text-decoration: underline;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(44, 44, 44, 0.2);
    text-align: left;
  }

  .prose :global(th) {
    background: rgba(44, 44, 44, 0.05);
    font-weight: 600;
  }
</style>
