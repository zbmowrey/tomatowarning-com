---
import { getEntry } from 'astro:content';
import { render } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';

const entry = await getEntry('pages', 'mission');

if (!entry) {
  return Astro.redirect('/');
}

// Build-time validation: fail if published without a charity partner name
if (entry.data.status === 'published') {
  const charityPartnerName = (entry.data as Record<string, unknown>).charityPartnerName;
  if (!charityPartnerName || String(charityPartnerName).trim() === '') {
    throw new Error(
      '[Mission Page] Build error: mission page is set to "published" but charityPartnerName is empty. ' +
      'Assign a charity partner before publishing this page.'
    );
  }
}

const { Content } = await render(entry);
const { title, seoTitle, seoDescription, lastUpdated, noIndex, status } = entry.data;

const formattedDate = lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout
  title={seoTitle}
  description={seoDescription}
  canonicalPath="/mission/"
  noIndex={noIndex ?? status === 'draft'}
>
  <article class="mission-page">
    <div class="prose-inner">
      {status === 'draft' && import.meta.env.DEV && (
        <div class="draft-banner" role="alert">
          <strong>Draft:</strong> This page is not published. It requires a charity partner to go live.
        </div>
      )}

      <header class="page-header">
        <h1>{title}</h1>
        <p class="last-updated">Last updated: <time datetime={lastUpdated.toISOString()}>{formattedDate}</time></p>
      </header>

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .mission-page {
    padding: 3rem 1.5rem;
  }

  .prose-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .draft-banner {
    background: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 2rem;
    color: #856404;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(44, 44, 44, 0.15);
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--storm-charcoal);
  }

  .last-updated {
    font-size: 0.875rem;
    color: var(--storm-charcoal);
    opacity: 0.6;
    margin: 0;
  }

  .prose {
    color: var(--storm-charcoal);
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .prose :global(a) {
    color: var(--radar-teal);
    text-decoration: underline;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(44, 44, 44, 0.2);
    text-align: left;
  }

  .prose :global(th) {
    background: rgba(44, 44, 44, 0.05);
    font-weight: 600;
  }
</style>
