# Astro public env vars (used at build time)
PUBLIC_EMAIL_FORM_ENDPOINT=http://localhost:8787/subscribe
PUBLIC_PRESS_INQUIRY_ENDPOINT=http://localhost:8787/press

# Brevo list IDs (integers from your Brevo dashboard)
PUBLIC_CONSUMER_LIST_ID=
PUBLIC_RETAILER_LIST_ID=
PUBLIC_NONPROFIT_LIST_ID=

# Worker secrets (set via `wrangler secret put BREVO_API_KEY`)
# BREVO_API_KEY=  # never commit this
